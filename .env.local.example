# Local Supabase development.
# Copy this file to `.env.local` and fill values from the Supabase dashboard.
# The server loads env files in this priority:
#   .env.development.local > .env.local > .env.development > .env

PORT=4000
# ENABLE_SWAGGER=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional local overrides
SUPABASE_STORAGE_ORDER_PHOTOS_BUCKET=order-photos
ORDER_PHOTOS_SIGNED_URL_TTL_SEC=900
EMERGENCY_DEFAULT_PRODUCT_ID=b2000001-0000-4000-8000-000000000001
