PORT=4000

# 브라우저에서 카탈로그·주문 API 호출 시 — 쉼표로 여러 출처 허용
# 코드 기본값에 airconecall.vercel.app 이 포함되어 있습니다. 커스텀 도메인이면 여기에 추가하세요.
# 로컬: `npm run dev` 가 NODE_ENV=development 로 기동되어 CORS 로 루프백+Vite 허용.
# `NODE_ENV=production` 으로 Nest 만 로컬에 띄우면 목록 외 차단되므로, CORS 에 localhost 포함하거나 다음을 쓰세요:
# LOCAL_RELAX_CORS=1
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://airconecall.vercel.app,https://예시.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://airconecall.vercel.app

# 선택: 강제로 모의 결제 허용(프로덕션 테스트 시에만)
# ENABLE_MOCK_PAYMENTS=true
# 선택: 어떤 NODE_ENV 에서라도 모의 결제 차단 — 실서버 운영 시 권장
# DISABLE_MOCK_PAYMENTS=true
# 기본 규칙: NODE_ENV !== 'production' 이면 mock-confirm 허용(.env 없이 로컬 개발 가능).

# --- Supabase(옵션) — 두 값 모두 설정 시 주문·결제 행 저장 + 카탈로그는 DB 로드 및 관리자 변경 시 DB 반영(Phase 2).
# 카탈로그가 비어 있으면 서버 기동 시 fixture 기준 자동 upsert 후 사용.
# FK 맞춤: 가능하면 service_catalog_seed.sql 로 시드(UUID가 fixture/order 와 동일).

# Phase 3: 기사·작업사진 DDL — APPLY_ORDER 의 technicians_and_order_photos.sql
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# 작업사진 업로드 — Supabase Storage 버킷(대시보드에서 생성 후 공개 읽기 또는 객체 정책 설정 권장)
# SUPABASE_STORAGE_ORDER_PHOTOS_BUCKET=order-photos
# 비공개 버킷: DDL settlement_audit_and_photo_paths.sql 적용 후 초 단위 TTL(0=서명 없이 url 컬럼 그대로)
# ORDER_PHOTOS_SIGNED_URL_TTL_SEC=900

# 관리자 JWT 부트스트랩(운영은 Supabase Auth·SSO 등으로 교체 권장)
# ADMIN_JWT_SECRET=change-me-min-16-chars____________
# ADMIN_BOOTSTRAP_PASSWORD=dev-only_______________
# 레거시 헤더 차단: ADMIN_LEGACY_X_ADMIN_ROLE=false

# 정산 감사 DB: sql/settlement_audit_and_photo_paths.sql

# 긴급 접수 마감 시 자동 설치 주문 초안 생성에 사용(카탈로그에 있는 활성 상품 UUID). 미설정·무효 시 첫 활성 설치 상품으로 폴백(경고 로그).
# EMERGENCY_DEFAULT_PRODUCT_ID=b2000001-0000-4000-8000-000000000001

# --- Toss Payments (C팀 주문·결제 스프린트용 — 개발자센터에서 테스트 키 발급) ---
# 고객 결제 준비/승인 API 구현 시 사용
TOSS_PAYMENTS_SECRET_KEY=
TOSS_PAYMENTS_CLIENT_KEY=
# TOSS_WEBHOOK_SECRET=
